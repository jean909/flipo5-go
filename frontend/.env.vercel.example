# ============================================
# Variabile de mediu pentru Vercel (Production)
# ============================================
# Adaugă în: Vercel Dashboard → Project → Settings → Environment Variables
# Bifează: Production (și opțional Preview / Development dacă vrei același set)
# ============================================

# Backend API – URL-ul public al API-ului (ex: subdomeniu sau domeniu unde rulează backend-ul)
NEXT_PUBLIC_API_URL=https://api.flipo5.com

# Site-ul public (pentru SEO, canonical URLs, Open Graph)
NEXT_PUBLIC_SITE_URL=https://flipo5.com

# Supabase – din Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Opțional – dezactivează telemetria Next.js la build
# NEXT_TELEMETRY_DISABLED=1
