# Copy on server: cp .env.example .env  then edit: nano .env
# Used by docker-compose (env_file: .env)

PORT=8080
JWT_SECRET=change-me-min-32-chars-in-production

# Database (Supabase direct connection, port 5432)
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres?sslmode=require

# Redis (local on server or Upstash URL)
REDIS_URL=redis://localhost:6379

# Replicate (replicate.com)
REPLICATE_API_TOKEN=

# Supabase (same project as frontend)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Optional: CORS (comma-separated)
# CORS_ORIGINS=http://localhost:3000,https://app.flipo5.com

# Optional: R2/S3
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_BUCKET_NAME=
# S3_PUBLIC_URL=https://...
